{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "**/*.{png,jpg,jpeg,webp,avif,PNG,JPG,JPEG,svg,ico,css,js,otf,woff,woff2}", "use": "@vercel/static" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/index.html" }
  ]
}
